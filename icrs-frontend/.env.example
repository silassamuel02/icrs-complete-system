# ICRS Frontend Environment Variables

# API URL for Spring Boot Backend
# Local: http://localhost:8080/api
# Production: https://your-backend.com/api
VITE_API_URL=http://localhost:8080/api

# AI Backend Host (FastAPI) - Only the Host/Port
# Local: localhost:8000
# Production: your-ai-backend.com
VITE_AI_URL=localhost:8000
